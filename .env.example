# Copie para .env.local e preencha. NÃO comite .env.local.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx   # ou o JWT 'anon'

# A service_role / sb_secret_ NÃO entra no frontend. Use só no backend do crawler (n8n),
# em variável de ambiente do servidor, jamais com prefixo NEXT_PUBLIC_ e jamais no Git.

# Chat com IA (/api/chat) — o host MCP é agnóstico de provedor.
# Configure UMA das chaves abaixo (DeepSeek tem prioridade se ambas existirem).
# DeepSeek (OpenAI-compatible): https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-xxx
# DEEPSEEK_MODEL=deepseek-chat
# Claude API: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_MODEL=claude-opus-4-8
